---
layout: base.njk
locale: en
title: Patterns
---

{# Hero Section #}
<div class="mb-10">
  <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-3">{{ site.name.en }}</h1>
  <p class="text-lg text-text-secondary max-w-2xl">{{ site.description.en }}</p>
  <p class="mt-3 text-sm text-text-muted">{{ patterns.length }} patterns across {{ categories | length }} categories</p>
</div>

{# Category Filter (Mobile) #}
<div class="lg:hidden mb-6">
  <select onchange="scrollToCategory(this.value)" class="w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-text-primary focus:border-accent focus:outline-none">
    <option value="">All patterns</option>
    {% for cat in categories %}
    <option value="{{ cat.slug }}">{{ cat.en }}</option>
    {% endfor %}
  </select>
</div>

{# Patterns by Category #}
{% for cat in categories %}
{% set catPatterns = patterns | filterByCategory(cat.slug) %}
{% if catPatterns | length > 0 %}
<section id="{{ cat.slug }}" class="mb-14 scroll-mt-28">
  <div class="flex items-center gap-3 mb-5">
    <div class="w-9 h-9 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
      <span class="text-accent-light">{{ cat.slug | categoryIcon | safe }}</span>
    </div>
    <h2 class="text-lg font-semibold text-text-primary">{{ cat.en }}</h2>
    <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-surface-elevated text-text-muted">{{ catPatterns | length }}</span>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {% for pattern in catPatterns %}
    <a href="/en/patterns/{{ pattern.slug }}/" class="pattern-card-compact group block">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-accent/10 text-accent font-bold text-sm flex items-center justify-center">{{ pattern.id }}</div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-text-primary group-hover:text-accent transition-colors leading-snug mb-1">{{ pattern.title.en }}</h3>
          {% if pattern.what and pattern.what.en %}
          <p class="text-xs text-text-muted leading-relaxed line-clamp-2">{{ pattern.what.en }}</p>
          {% endif %}
        </div>
      </div>
      <div class="mt-3 flex items-center justify-between">
        <span class="text-xs px-2 py-0.5 rounded-full bg-surface-elevated text-text-muted border border-border">{{ pattern.categoryLabel.en }}</span>
        <span class="text-xs text-accent opacity-0 group-hover:opacity-100 transition-opacity font-medium">View →</span>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
{% endfor %}

<footer class="mt-16 pt-8 border-t border-border text-center text-sm text-text-muted">
  <p>{{ site.name.en }} — <a href="https://github.com" class="text-accent hover:text-accent-light" target="_blank" rel="noopener">GitHub</a></p>
</footer>
