---
layout: base.njk
locale: en
title: Patterns
---

{% from "pattern-card.njk" import pattern_card %}

{# Hero Section #}
<div class="mb-10">
  <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
    {{ site.name.en }}
  </h1>
  <p class="text-lg text-text-secondary max-w-2xl">
    {{ site.description.en }}
  </p>
  <div class="mt-6 flex flex-wrap items-center gap-3">
    <span class="text-sm text-text-muted">{{ patterns.length }} patterns • 10 categories</span>
    <span class="text-text-muted">•</span>
    <button onclick="expandAll()" class="text-sm text-accent hover:text-accent-light transition-colors">
      Expand all
    </button>
    <span class="text-text-muted">•</span>
    <button onclick="collapseAll()" class="text-sm text-accent hover:text-accent-light transition-colors">
      Collapse all
    </button>
  </div>
</div>

{# Category Filter (Mobile) #}
<div class="lg:hidden mb-6">
  <select onchange="scrollToCategory(this.value)" class="w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-text-primary focus:border-accent focus:outline-none">
    <option value="">{{ i18n.all_patterns[locale] }}</option>
    {% for cat in categories %}
    <option value="{{ cat.slug }}">{{ cat.en }}</option>
    {% endfor %}
  </select>
</div>

{# Patterns by Category #}
{% for cat in categories %}
<section id="{{ cat.slug }}" class="mb-12 scroll-mt-28">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
      <span class="text-accent-light">{{ cat.slug | categoryIcon | safe }}</span>
    </div>
    <h2 class="text-xl font-semibold text-text-primary">{{ cat.en }}</h2>
    <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-surface-elevated text-text-muted">
      {{ patterns | filterByCategory(cat.slug) | length }}
    </span>
  </div>

  <div class="space-y-6">
    {% for pattern in patterns %}
    {% if pattern.category == cat.slug %}
    {{ pattern_card(pattern, locale) }}
    {% endif %}
    {% endfor %}
  </div>
</section>
{% endfor %}

{# Footer #}
<footer class="mt-16 pt-8 border-t border-border text-center text-sm text-text-muted">
  <p>
    {{ site.name.en }} — <a href="https://github.com" class="text-accent hover:text-accent-light" target="_blank" rel="noopener">GitHub</a>
  </p>
</footer>