{% macro pattern_card(pattern, locale) %}
<article id="{{ pattern.slug }}" class="pattern-card scroll-mt-24">
  {# Header #}
  <div class="pattern-card-header">
    <div class="pattern-number">{{ pattern.id }}</div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h2 class="text-lg font-semibold text-text-primary">{{ pattern.title[locale] }}</h2>
        <span class="category-badge">{{ pattern.categoryLabel[locale] }}</span>
      </div>
    </div>
    <a href="#{{ pattern.slug }}" class="p-2 rounded-lg hover:bg-surface-hover text-text-muted hover:text-text-primary transition-colors" title="Copy link"
      onclick="copyToClipboard('{{ pattern.slug }}'); return false;"
    >
      <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
        <path d="M12.232 4.232a2.5 2.5 0 013.536 3.536l-1.225 1.224a.75.75 0 001.061 1.06l1.224-1.224a4 4 0 00-5.656-5.656l-3 3a4 4 0 00-.225 5.865.75.75 0 00.977-1.138 2.5 2.5 0 01.142-3.667l3-3z" />
        <path d="M11.603 7.963a.75.75 0 00-.977 1.138 2.5 2.5 0 01.142 3.667l-3 3a2.5 2.5 0 01-3.536-3.536l1.225-1.224a.75.75 0 00-1.061-1.06l-1.224 1.224a4 4 0 105.656 5.656l3-3a4 4 0 00-.225-5.865z" />
      </svg>
    </a>
  </div>

  {# Content #}
  <div class="p-5 space-y-4">
    {# What #}
    {% if pattern.what %}
    <div class="section" data-section="what">
      <button class="section-toggle" onclick="toggleSection(this)">
        <span>{{ i18n.what[locale] }}</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 transition-transform">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="section-content hidden">
        <p class="text-text-secondary">{{ pattern.what[locale] }}</p>
      </div>
    </div>
    {% endif %}

    {# Why #}
    {% if pattern.why %}
    <div class="section" data-section="why">
      <button class="section-toggle" onclick="toggleSection(this)">
        <span>{{ i18n.why[locale] }}</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 transition-transform">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="section-content hidden">
        <p class="text-text-secondary">{{ pattern.why[locale] }}</p>
      </div>
    </div>
    {% endif %}

    {# Demo #}
    {% if pattern.demo %}
    <div class="section" data-section="demo">
      <button class="section-toggle" onclick="toggleSection(this)">
        <span>{{ i18n.demo[locale] }}</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 transition-transform">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="section-content hidden">
        <div class="demo-block">
          <pre>{{ pattern.demo.fr | replace(r/^```/, "") | replace(r/```$/, "") | trim }}</pre>
        </div>
        <button class="mt-2 flex items-center gap-1.5 text-xs text-text-muted hover:text-text-primary transition-colors" onclick="copyCode(this)">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M7 3.5A1.5 1.5 0 018.5 2h3.879a1.5 1.5 0 011.06.44l3.122 3.12A1.5 1.5 0 0117 6.622V12.5a1.5 1.5 0 01-1.5 1.5h-1v-3.879a1.5 1.5 0 00-.44-1.06L10.939 5.44A1.5 1.5 0 009.879 5H7v-1.5z" />
            <path d="M3.5 7A1.5 1.5 0 002 8.5v7A1.5 1.5 0 003.5 17h7a1.5 1.5 0 001.5-1.5v-5.879a1.5 1.5 0 00-.44-1.06L8.621 5.439A1.5 1.5 0 007.56 5H3.5z" />
          </svg>
          <span>{{ i18n.copy[locale] }}</span>
        </button>
      </div>
    </div>
    {% endif %}

    {# Examples #}
    {% if pattern.examples and pattern.examples.length > 0 %}
    <div class="section" data-section="examples">
      <button class="section-toggle" onclick="toggleSection(this)">
        <span>{{ i18n.examples[locale] }}</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 transition-transform">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="section-content hidden">
        <ul class="space-y-2">
          {% for example in pattern.examples %}
          <li class="flex items-start gap-2">
            <span class="font-medium text-text-primary">{{ example.name }}</span>
            <span class="text-text-muted">—</span>
            <span class="text-text-secondary">{{ example.desc[locale] }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}

    {# Implementation Guide #}
    {% if pattern.guide and pattern.guide.length > 0 %}
    <div class="section" data-section="guide">
      <button class="section-toggle" onclick="toggleSection(this)">
        <span>{{ i18n.guide[locale] }}</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 transition-transform">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="section-content hidden">
        <ul class="guide-list space-y-1">
          {% for item in pattern.guide %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}

    {# Pitfalls #}
    {% if pattern.pitfalls and pattern.pitfalls.length > 0 %}
    <div class="section" data-section="pitfalls">
      <button class="section-toggle" onclick="toggleSection(this)">
        <span>{{ i18n.pitfalls[locale] }}</span>
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 transition-transform">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="section-content hidden">
        <ul class="pitfalls-list space-y-1">
          {% for item in pattern.pitfalls %}
          {% if item != '--' %}
          <li>{{ item | replace(r/^❌\s*/, '') | safe }}</li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}
  </div>
</article>
{% endmacro %}
